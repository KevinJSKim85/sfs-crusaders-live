rules_version = '2';

// Firestore security rules for SFS Crusader Hub.
// - Public read for everything under /config and /announcements (the dashboard
//   reads these without auth).
// - Writes require an authenticated Google account whose email is in the
//   admin allowlist below.
//
// IMPORTANT: keep the admin email list in sync with window.ADMIN_EMAILS in
// firebase-config.js. The client-side check is convenience; this server-side
// rule is the real gate.

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email in [
               "sfsdashboard@gmail.com"
             ];
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
